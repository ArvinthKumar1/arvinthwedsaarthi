{
  "routes": [
    {
      "route": "/login",
      "redirect": "/approval.html"
    },
    {
      "route": "/logout",
      "redirect": "/approval.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/approval.html", "/api/*", "/*.css", "/*.js", "/*.png", "/*.jpg", "/*.svg"]
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}